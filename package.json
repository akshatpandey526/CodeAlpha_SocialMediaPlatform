{
  "name": "vibe-codealpha-root",
  "version": "1.0.0",
  "description": "Root configuration to run Vibe-CodeAlpha client and server concurrently",
  "scripts": {
    "server": "npm run dev --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
